# Impect Football Data API (required)
IMPECT_USERNAME=your_email@port-vale.co.uk
IMPECT_PASSWORD=your_password
IMPECT_CLIENT_ID=api
IMPECT_TOKEN_URL=https://login.impect.com/auth/realms/production/protocol/openid-connect/token
IMPECT_BASE_URL=https://api.impect.com
IMPECT_API_PREFIX=customerapi

# Fixture assignment emails (optional — Microsoft 365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sam.baker@port-vale.co.uk
SMTP_PASSWORD=your_mailbox_or_app_password
FIXTURE_EMAIL_FROM=sam.baker@port-vale.co.uk
FIXTURE_EMAIL_FROM_NAME=Sam Baker · Port Vale Recruitment

# Paths (defaults work for local dev — Docker overrides DATA_ROOT)
# HUB_ROOT=/path/to/impect-football-dashboard
# DATA_ROOT=/path/to/persistent/data
# STRATEGY_REPORTS_DIR=/path/to/strategy-reports

# Post-match defaults (optional overrides)
# PORT_VALE_SQUAD_ID=882
# DEFAULT_MATCH_ID=216415
# DEFAULT_ITERATION_ID=1465

# Server bind (use 0.0.0.0 for team access on LAN or cloud)
HOST=127.0.0.1
PORT=8000

# Team login (production — leave TEAM_PASSWORD empty for local dev without login)
# Single user for now; multi-user management planned later.
# TEAM_USERNAME=PortVale
# TEAM_PASSWORD=JoyPortVale123!
# HUB_AUTH_SECRET=long_random_string_for_session_cookies

# PDF export save location (optional)
# EXPORT_DESKTOP_PATH=/Users/you/Desktop
